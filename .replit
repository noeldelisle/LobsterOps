modules = ["nodejs-20", "python-3.11"]

[nix]
channel = "stable-25_05"

[deployment]
deploymentTarget = "cloudrun"
run = ["sh", "-c", "cd /home/runner/workspace && node server.js"]

[[ports]]
localPort = 3000
externalPort = 80

[workflows]
runButton = "Start"

[[workflows.workflow]]
name = "Start"
author = "user"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && node server.js"

[agent]
expertMode = true
